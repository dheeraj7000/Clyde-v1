# Pick one provider (or none for demo mode)

# OpenRouter (recommended) — get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Cerebras (optional fast inference) — https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Provider preference: auto | openrouter | cerebras | mock
CLYDE_LLM_PROVIDER=auto

# Model override (e.g. anthropic/claude-3.5-haiku, meta-llama/llama-3.3-70b-instruct)
CLYDE_MODEL=

# Cerebras-specific model override
CLYDE_CEREBRAS_MODEL=

# Web server
CLYDE_HOST=0.0.0.0
CLYDE_PORT=8000
